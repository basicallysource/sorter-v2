ENVIRONMENT=production
HIVE_DOMAIN=hive.neuhaus.nrw

POSTGRES_DB=hive
POSTGRES_USER=hive
POSTGRES_PASSWORD=replace-with-strong-password

JWT_SECRET=replace-with-long-random-secret
SECRET_ENCRYPTION_KEY=replace-with-generated-fernet-key
UPLOAD_DIR=/data/uploads
# STORAGE_BACKEND: "local" (disk at UPLOAD_DIR) or "s3" (S3-compatible, e.g. DO Spaces)
STORAGE_BACKEND=local
# S3 / DO Spaces config — only used when STORAGE_BACKEND=s3
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_SERVE_MODE: "redirect" (307 to presigned URL, cheap) or "stream" (proxy through backend)
S3_SERVE_MODE=redirect
S3_PRESIGNED_EXPIRY_SECONDS=3600
CORS_ORIGIN=https://hive.neuhaus.nrw
APP_BASE_URL=https://hive.neuhaus.nrw
COOKIE_SECURE=true

ADMIN_EMAIL=admin@hive.neuhaus.nrw
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_DISPLAY_NAME=Hive Admin

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://hive.neuhaus.nrw/api/auth/github/callback
