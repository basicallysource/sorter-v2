# --- Sorter station environment -------------------------------------------------------------
# Copy to .env and edit the absolute paths for your machine. Loaded automatically by app.py.

# Where ALL persistent machine state lives (camera assignment, polygons, aruco config,
# baselines, calibration, machine id). Survives re-cloning the repo. Defaults to the client/
# folder if unset.
export CONFIG_DIR="/home/user/sorter-v2/software/client"

export DEBUG_LEVEL=2
export LOG_BUFFER_SIZE=100

# Sorting profile (which part/category -> which bin) and machine-specific hardware overrides
# (bin layout, stepper current/speed, chute/servo angles). See
# client/irl/example_configs/machine_specific_params_example.toml.
export SORTING_PROFILE_PATH="/home/user/sorter-v2/software/client/sorting_profile.json"
export MACHINE_SPECIFIC_PARAMS_PATH="/home/user/sorter-v2/software/client/irl/example_configs/machine_specific_params_example.toml"

# Parts metadata — used by the standalone sorting_profile_builder app (pulled via Git LFS).
export PARTS_WITH_CATEGORIES_FILE_PATH="/home/user/sorter-v2/software/client/parts_with_categories.json"

# Telemetry (optional; off by default).
export TELEMETRY_ENABLED=0
export TELEMETRY_URL="https://api.basically.website"

# BrickLink API credentials (optional; enables richer part metadata in the UI).
export BL_CONSUMER_KEY="no"
export BL_CONSUMER_SECRET="no"
export BL_TOKEN_VALUE="no"
export BL_TOKEN_SECRET="no"

# Cameras + Picos are auto-detected; cameras are assigned in the web Setup wizard (no env vars).
