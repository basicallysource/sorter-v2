export DEBUG_LEVEL=2
export PYTHONUNBUFFERED=1

# Optional explicit serial port override (otherwise auto-discovered)
# export MCU_PATH="/dev/tty.usbmodemXXXX"

export MACHINE_SPECIFIC_PARAMS_PATH="/home/user/sorter-v2/software/machine.example.toml"
export SORTING_PROFILE_PATH="/home/user/sorter-v2/software/sorter/backend/sorting_profile.json"
export OPENROUTER_API_KEY="no"
export HIVE_TOKEN="no"

export PROFILER_ENABLED=0
export PROFILER_REPORT_INTERVAL_S=30

export WRITE_CAMERA_FEEDS=0

# Max width (px) of the MJPEG preview stream. The annotated frame is
# downscaled to this width before JPEG encoding. Annotation still runs at
# full capture resolution — this only shrinks bytes-on-wire and encode CPU.
# Set 0 to disable resizing.
export SORTER_PREVIEW_MAX_WIDTH=960

# Wider input frames get downscaled to this width before MOG2 runs.
# Detection bboxes are scaled back to camera-frame coords automatically,
# so downstream tracking/overlays are unaffected. Set for the carousel
# (4K → 720 = ~28x pixel reduction); 720p inputs pass through untouched.
# Set 0 to disable.
export SORTER_MOG2_MAX_INPUT_WIDTH=720