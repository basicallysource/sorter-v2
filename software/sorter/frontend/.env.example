PUBLIC_BACKEND_BASE_URL=http://localhost:8000
PUBLIC_BACKEND_WS_URL=ws://localhost:8000

# Comma-separated extra hostnames the vite dev server should accept.
# Defaults already allow *.ts.net (Tailscale) and *.local (mDNS).
# Set this when reaching the dev server via a non-mDNS LAN hostname or alias.
# SORTER_ALLOWED_HOSTS=sorter-orangepi01,my-other-host
